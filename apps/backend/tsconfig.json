{
    "compilerOptions":  {
                            "target":  "ES2021",
                            "module":  "CommonJS",
                            "moduleResolution":  "Node",
                            "rootDir":  "src",
                            "outDir":  "dist",
                            "esModuleInterop":  true,
                            "allowSyntheticDefaultImports":  true,
                            "resolveJsonModule":  true,
                            "forceConsistentCasingInFileNames":  true,
                            "strict":  true,
                            "skipLibCheck":  true,
                            "declaration":  true,
                            "declarationMap":  true,
                            "sourceMap":  true
                        },
    "include":  [
                    "src"
                ],
    "exclude":  [
                    "src/**/*.test.ts",
                    "src/**/*.spec.ts"
                ]
}
