    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "prebuild": "bun run --filter '@opendock/shared' build && prisma generate",
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "predev": "bun run --filter '@opendock/shared' build && prisma generate",
        "start": "node dist/index.js",
        "db:generate": "prisma generate",
        "db:push": "prisma db push",
        "db:studio": "prisma studio",
        "seed": "ts-node src/seed.ts",
        "test": "vitest"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "prisma": {
        "schema": "src/dal/sql/prisma/schema.prisma"
    },
    "dependencies": {
        "@opendock/shared": "workspace:^0.1.0",
        "@prisma/client": "^5.18.0",
        "bcryptjs": "^2.4.3",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^5.1.0",
        "multer": "^2.0.2",
        "node-cron": "^4.2.1",
        "supertest": "^7.1.1",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cookie-parser": "^1.4.7",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.3",
        "@types/multer": "^2.0.0",
        "@types/node": "^24.8.1",
        "@types/supertest": "^2.0.16",
        "prisma": "^5.18.0",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
