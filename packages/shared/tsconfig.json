{
    "compilerOptions":  {
                            "target":  "ES2021",
                            "module":  "ESNext",
                            "moduleResolution":  "Node",
                            "strict":  true,
                            "esModuleInterop":  true,
                            "skipLibCheck":  true,
                            "outDir":  "./dist",
                            "declaration":  true,
